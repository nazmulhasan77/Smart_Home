{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid",
        
        "devices": {
          "$deviceId": {
            ".read": "auth.uid === $uid",
            ".write": "auth.uid === $uid",
            "switches": {
              "$switchId": {
                ".read": "auth.uid === $uid",
                ".write": "auth.uid === $uid"
              }
            }
          }
        },
        
        "schedules": {
          "$scheduleId": {
            ".read": "auth.uid === $uid",
            ".write": "auth.uid === $uid"
          }
        }
      }
    }
  }
}
